    "@types/pg": "^8.16.0",
    "@types/slug": "5.0.9",
    "@vitest/ui": "3.2.4",
    "dotenv": "^17.2.1",
    "drizzle-kit": "^0.31.8",
    "pino-pretty": "13.1.1",
