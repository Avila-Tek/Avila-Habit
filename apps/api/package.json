{
  "name": "@repo/api",
  "version": "0.1.0",
  "description": "API Gateway for the backend app",
  "main": "dist/index.js",
  "scripts": {
    "check:types": "tsc --noEmit",
    "build": "tsup",
    "start": "node dist/index.js",
    "dev": "tsx watch src .env pino-pretty --colorize",
    "test": "vitest",
    "test:watch": "vitest -w",
    "db:generate": "drizzle-kit generate",
